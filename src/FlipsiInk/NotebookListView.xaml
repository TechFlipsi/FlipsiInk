<Window x:Class="FlipsiInk.NotebookListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notizbücher – FlipsiInk"
        Width="900" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <DockPanel>
        <!-- Top bar: search + view toggle + new button -->
        <DockPanel DockPanel.Dock="Top" Background="#2D2D2D" Height="48" Margin="0">
            <Button x:Name="BtnNewNotebook" Content="➕ Neu" DockPanel.Dock="Right"
                    Style="{StaticResource AccentButton}" Margin="8,6" ToolTip="Neues Notizbuch erstellen"/>
            <Button x:Name="BtnToggleView" Content="▤" DockPanel.Dock="Right"
                    Width="40" Height="40" Margin="0,4,4,4"
                    Background="#2D2D2D" Foreground="White" BorderBrush="#444"
                    ToolTip="Raster-/Listenansicht wechseln" Cursor="Hand"/>
            <TextBox x:Name="SearchBox" DockPanel.Dock="Left"
                     Width="260" Height="30" Margin="10,0,8,0"
                     VerticalContentAlignment="Center"
                     Background="#1E1E1E" Foreground="White"
                     BorderBrush="#444" FontSize="14"
                     ToolTip="Notizbücher durchsuchen (Titel, Autor, Beschreibung)"/>
        </DockPanel>

        <!-- Notebook grid/list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="NotebookList"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     Margin="8"
                     SelectionMode="Single"
                     MouseDoubleClick="NotebookList_MouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- Default: wrap panel (grid) -->
                        <WrapPanel x:Name="ItemsPanel"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Öffnen" Click="MenuOpen_Click"/>
                        <MenuItem Header="Eigenschaften" Click="MenuProperties_Click"/>
                        <MenuItem Header="⭐ Favorit" Click="MenuFavorite_Click"/>
                        <Separator/>
                        <MenuItem Header="Löschen" Click="MenuDelete_Click"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>
        </ScrollViewer>
    </DockPanel>
</Window>