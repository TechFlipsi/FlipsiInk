<Window x:Class="FlipsiInk.NotebookListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlipsiInk"
        Width="1000" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        WindowStyle="SingleBorderWindow">

    <Grid>
        <!-- ═══ Collapsible Sidebar ═══ -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,0,1,0" x:Name="Sidebar">
            <DockPanel Margin="8">
                <!-- Profile / App Icon -->
                <Border DockPanel.Dock="Top" Background="#252525" CornerRadius="10" Padding="12,8" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="18" Background="#0078D7">
                            <TextBlock Text="F" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="FlipsiInk" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SidebarNoteCount" Text="0 Notizb&#xFC;cher" Foreground="#888" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Search -->
                <TextBox DockPanel.Dock="Top" x:Name="SearchBox" 
                         Height="32" Margin="0,0,0,12"
                         VerticalContentAlignment="Center"
                         Background="#252525" Foreground="White"
                         BorderBrush="#444" BorderThickness="1"
                         FontSize="13" Padding="8,0"
                         ToolTip="Notizb&#xFC;cher durchsuchen"/>

                <!-- Sidebar navigation items -->
                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="NavAll" Content="&#x2630; Alle Notizb&#xFC;cher" Background="Transparent" Foreground="White" BorderThickness="0" Padding="8,6" FontSize="13" HorizontalContentAlignment="Left" Cursor="Hand" Click="NavAll_Click" Margin="0,0,0,2"/>
                    <Button x:Name="NavFavorites" Content="&#x2605; Favoriten" Background="Transparent" Foreground="#CCCCCC" BorderThickness="0" Padding="8,6" FontSize="13" HorizontalContentAlignment="Left" Cursor="Hand" Click="NavFavorites_Click" Margin="0,0,0,2"/>
                    <Button x:Name="NavRecent" Content="&#x23F0; K&#xFC;rzlich ge&#xF6;ffnet" Background="Transparent" Foreground="#CCCCCC" BorderThickness="0" Padding="8,6" FontSize="13" HorizontalContentAlignment="Left" Cursor="Hand" Click="NavRecent_Click" Margin="0,0,0,8"/>
                </StackPanel>

                <!-- Folder tree placeholder -->
                <TextBlock DockPanel.Dock="Top" Text="Ordner" Foreground="#888" FontSize="12" FontWeight="SemiBold" Margin="4,4,0,4"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="FolderTree">
                        <Button x:Name="NavFolderRoot" Content="&#x25B7; Alle Dateien" Background="Transparent" Foreground="#CCC" BorderThickness="0" Padding="8,4" FontSize="12" HorizontalContentAlignment="Left" Cursor="Hand" Click="NavFolderRoot_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ Main Content Area ═══ -->
        <Grid Grid.Column="1">
            <!-- Top bar with view toggle -->
            <DockPanel DockPanel.Dock="Top" Height="48" Background="#1A1A1A" Margin="0">
                <Border Background="#333" Height="1" DockPanel.Dock="Bottom" Opacity="0.5"/>
                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock x:Name="SectionTitle" Text="Alle Notizb&#xFC;cher" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FilterCount" Text="" Foreground="#888" FontSize="12" Margin="8,2,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,0" VerticalAlignment="Center">
                    <Button x:Name="BtnToggleView" Content="&#x25A6;" Width="32" Height="32" Margin="0,0,4,0"
                            Background="#252525" Foreground="White" BorderBrush="#444" BorderThickness="1"
                            ToolTip="Raster-/Listenansicht" Cursor="Hand" Click="BtnToggleView_Click"/>
                    <Button x:Name="BtnSortBy" Content="&#x2195;" Width="32" Height="32"
                            Background="#252525" Foreground="White" BorderBrush="#444" BorderThickness="1"
                            ToolTip="Sortieren" Cursor="Hand" Click="BtnSortBy_Click"/>
                </StackPanel>
            </DockPanel>

            <!-- Notebook grid with cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <ItemsControl x:Name="NotebookGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel x:Name="ItemsPanel"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- ═══ FAB (Floating Action Button) ═══ -->
            <Button x:Name="BtnNewNotebook" 
                    Content="&#xFF0B;" 
                    Style="{StaticResource FABButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,24,24"
                    ToolTip="Neues Notizbuch erstellen"
                    Click="BtnNewNotebook_Click"/>
        </Grid>
    </Grid>
</Window>