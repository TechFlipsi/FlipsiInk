<Application x:Class="FlipsiInk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- ═══════════════════════════════════════════════════════════
             FLIPSIINK v0.4.0 – "Canvas First" Design System
             Inspired by Notewise + Nebo: Mica/Acrylic, rounded corners,
             soft shadows, maximum workspace, minimal chrome.
             ═══════════════════════════════════════════════════════════ -->

        <!-- Accent Colors -->
        <Color x:Key="AccentColor">#0078D7</Color>
        <Color x:Key="AccentHoverColor">#1A8FEF</Color>
        <Color x:Key="AccentPressedColor">#005A9E</Color>
        <Color x:Key="DangerColor">#D32F2F</Color>

        <!-- Dark Theme Colors (Primary) -->
        <Color x:Key="CanvasBgDark">#000000</Color>
        <Color x:Key="PanelBgDark">#1E1E1E</Color>
        <Color x:Key="PanelBg2Dark">#252525</Color>
        <Color x:Key="TopBarBgDark">#1A1A1A</Color>
        <Color x:Key="ToolbarBgDark">#CC252525</Color>
        <Color x:Key="CardBgDark">#2A2A2A</Color>
        <Color x:Key="CardHoverDark">#333333</Color>
        <Color x:Key="BorderDark">#3A3A3A</Color>
        <Color x:Key="TextPrimaryDark">#FFFFFF</Color>
        <Color x:Key="TextSecondaryDark">#AAAAAA</Color>
        <Color x:Key="TextMutedDark">#666666</Color>

        <!-- Light Theme Colors -->
        <Color x:Key="CanvasBgLight">#FFFFFF</Color>
        <Color x:Key="PanelBgLight">#F5F5F5</Color>
        <Color x:Key="PanelBg2Light">#ECECEC</Color>
        <Color x:Key="TopBarBgLight">#FAFAFA</Color>
        <Color x:Key="ToolbarBgLight">#DDFAFAFA</Color>
        <Color x:Key="CardBgLight">#FFFFFF</Color>
        <Color x:Key="CardHoverLight">#F0F0F0</Color>
        <Color x:Key="BorderLight">#E0E0E0</Color>
        <Color x:Key="TextPrimaryLight">#1E1E1E</Color>
        <Color x:Key="TextSecondaryLight">#555555</Color>
        <Color x:Key="TextMutedLight">#999999</Color>

        <!-- ═══ Shared CornerRadius Values ═══ -->
        <CornerRadius x:Key="CornerRadiusSm">6</CornerRadius>
        <CornerRadius x:Key="CornerRadiusMd">8</CornerRadius>
        <CornerRadius x:Key="CornerRadiusLg">12</CornerRadius>
        <CornerRadius x:Key="CornerRadiusPill">20</CornerRadius>

        <!-- ═══ Tool Button (shared base for all icon buttons) ═══ -->
        <Style TargetType="ButtonBase" x:Key="ToolButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="2" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Accent Button ═══ -->
        <Style TargetType="Button" x:Key="AccentButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A8FEF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ FAB (Floating Action Button) Style ═══ -->
        <Style TargetType="Button" x:Key="FABButton">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="28" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.4" Color="Black"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A8FEF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Dark-aware ComboBox ═══ -->
        <Style TargetType="ComboBox" x:Key="DarkComboBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <!-- ═══ Dark TextBox ═══ -->
        <Style TargetType="TextBox" x:Key="DarkTextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ═══ Section Header ═══ -->
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- ═══ Color Swatch Button ═══ -->
        <Style x:Key="ColorSwatchButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="14" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Pill Button (floating toolbar items) ═══ -->
        <Style TargetType="ButtonBase" x:Key="PillToolButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="2" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#383838"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Active Tool Button (highlighted state) ═══ -->
        <Style TargetType="ButtonBase" x:Key="PillToolButtonActive">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="2" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A8FEF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ContextMenu (for page overview flags) -->
        <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
    </Application.Resources>
</Application>