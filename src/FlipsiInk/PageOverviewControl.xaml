<!-- PageOverviewControl.xaml - Scrollable thumbnail grid with page flags -->
<UserControl x:Class="FlipsiInk.PageOverviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FlipsiInk"
             Background="#1A1A1A">
    <UserControl.Resources>
        <!-- Thumbnail card style -->
        <Style x:Key="ThumbCard" TargetType="Border">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D7"/>
                    <Setter Property="Background" Value="#333"/>
                </Trigger>
            </Style>
        </Style>
        <!-- Flag colors button style -->
        <Style x:Key="FlagColorButton" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
        <!-- Filter toggle button -->
        <Style x:Key="FilterButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
            <TextBlock x:Name="HeaderLabel" Text="Seitenuebersicht" FontWeight="SemiBold" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="PageCountLabel" Text="(1)" Foreground="#888" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
            <Button x:Name="BtnClose" Content="&#x2715;" HorizontalAlignment="Right" Margin="8,0,0,0"
                    Style="{StaticResource ToolButton}" Width="24" Height="24" FontSize="12"
                    ToolTip="Schliessen" Click="BtnClose_Click"/>
        </StackPanel>

        <!-- Filter bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,0,8,4">
            <ToggleButton x:Name="FilterAll" Content="Alle" IsChecked="True" Style="{StaticResource FilterButton}" Click="FilterAll_Click"/>
            <ToggleButton x:Name="FilterFlagged" Content="Markiert" IsChecked="False" Style="{StaticResource FilterButton}" Click="FilterFlagged_Click"/>
            <Button x:Name="BtnMarkCurrent" Content="Seite markieren" Style="{StaticResource ToolButton}" FontSize="10"
                    Padding="6,3" Margin="8,0,0,0" ToolTip="Aktuelle Seite markieren" Click="BtnMarkCurrent_Click"/>
        </StackPanel>

        <!-- Thumbnail grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="4">
            <ItemsControl x:Name="ThumbGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ThumbCard}" Tag="{Binding PageNumber}"
                                MouseLeftButtonUp="ThumbCard_Click"
                                MouseRightButtonUp="ThumbCard_RightClick">
                            <Grid>
                                <!-- Thumbnail -->
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Page preview area -->
                                <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="4" Margin="2" Height="90">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <!-- Flag indicator -->
                                        <Border x:Name="FlagIndicator" VerticalAlignment="Top" HorizontalAlignment="Right"
                                                Width="8" Height="24" CornerRadius="2" Margin="2"
                                                Background="{Binding FlagBrush}"
                                                Visibility="{Binding FlagVisibility}"/>
                                    </Grid>
                                </Border>
                                <!-- Page number label -->
                                <TextBlock Grid.Row="1" Text="{Binding Label}" Foreground="#AAA" FontSize="10"
                                           HorizontalAlignment="Center" Margin="0,2,0,2"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>