<Window x:Class="FlipsiInk.ModelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KI-Modelle verwalten" Width="720" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A8FEF" TargetName="bg"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E53935" TargetName="bg"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444" TargetName="bg"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="KI-Modelle" Style="{StaticResource HeaderLabel}" VerticalAlignment="Center"/>
            <TextBlock x:Name="ModelsDirLabel" DockPanel.Dock="Right" VerticalAlignment="Center"
                       Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <!-- Tier Legend -->
        <Border DockPanel.Dock="Top" Background="#252525" CornerRadius="10" Padding="12,8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Border Background="#2196F3" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="Mittel" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="8 GB RAM" Foreground="#999" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Border Background="#0078D7" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="Stark" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="16 GB RAM" Foreground="#999" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Border Background="#9C27B0" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="Premium" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="32 GB RAM" Foreground="#999" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- RAM Warning -->
        <Border x:Name="RamWarningBorder" DockPanel.Dock="Top" Background="#332200" CornerRadius="10" Padding="12,8" Margin="0,0,0,12" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x26A0;" FontSize="16" Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="RamWarningText" Text="Ihr System hat moeglicherweise nicht genug RAM fuer dieses Modell." Foreground="#FFB74D" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Progress bar area -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <StackPanel>
                <ProgressBar x:Name="DownloadProgress" Height="4" Minimum="0" Maximum="100" Value="0"
                             Foreground="#0078D7" Background="#333" Visibility="Collapsed"/>
                <TextBlock x:Name="StatusLabel" Text="" Foreground="#666" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Close button -->
        <DockPanel DockPanel.Dock="Bottom" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Schliessen" Style="{StaticResource SecondaryButton}" Click="Close_Click"/>
        </DockPanel>

        <!-- Model list -->
        <ListView x:Name="ModelList" Background="#1A1A1A" BorderThickness="1" BorderBrush="#333"
                  Foreground="White" SelectionMode="Single" Margin="0,0,0,8">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2A2A2A" CornerRadius="10" Padding="14,10" Margin="2">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.15" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Name + Badges -->
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="White" Margin="0,0,8,0"/>
                                <Border Background="#0078D7" CornerRadius="4" Padding="5,1" Visibility="{Binding RecommendedBadge}">
                                    <TextBlock Text="EMPFOHLEN" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                </Border>
                                <Border Background="#4CAF50" CornerRadius="4" Padding="5,1" Margin="4,0,0,0" Visibility="{Binding InstalledBadge}">
                                    <TextBlock Text="INSTALLIERT" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                </Border>
                                <Border Background="#FF9800" CornerRadius="4" Padding="5,1" Margin="4,0,0,0" Visibility="{Binding ActiveBadge}">
                                    <TextBlock Text="AKTIV" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                </Border>
                                <Border Background="#9C27B0" CornerRadius="4" Padding="5,1" Margin="4,0,0,0" Visibility="{Binding UpdateBadge}">
                                    <TextBlock Text="UPDATE" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                </Border>
                                <!-- Tier badge -->
                                <Border x:Name="TierBadge" CornerRadius="4" Padding="5,1" Margin="8,0,0,0" Background="{Binding TierColor}">
                                    <TextBlock Text="{Binding TierLabelShort}" FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <!-- Row 1: Description -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Description}" FontSize="11" Foreground="#AAA" Margin="0,2,0,0"/>

                            <!-- Row 2: Meta info -->
                            <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="0" Margin="0,4,0,0">
                                <TextBlock Text="{Binding Size}" FontSize="11" Foreground="#777" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding Quantization}" FontSize="11" Foreground="#777" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding RamRequirement}" FontSize="11" Foreground="#777" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding InstalledVersion}" FontSize="11" Foreground="#6A9" Margin="0,0,12,0"/>
                            </StackPanel>

                            <!-- Row 3: RAM requirement visual bar -->
                            <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="0" Margin="0,4,0,0">
                                <TextBlock Text="RAM:" FontSize="10" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Border Width="{Binding RamBarWidth}" Height="6" Background="{Binding TierColor}" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding RamGbLabel}" FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Actions -->
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <Button Content="Herunterladen" Style="{StaticResource ActionButton}"
                                        Visibility="{Binding DownloadVisible}" Click="Download_Click" Tag="{Binding Id}" Margin="0,0,4,0" FontSize="11"/>
                                <Button Content="Update" Style="{StaticResource ActionButton}"
                                        Visibility="{Binding UpdateVisible}" Click="Update_Click" Tag="{Binding Id}" Margin="0,0,4,0" FontSize="11"/>
                                <Button Content="Loeschen" Click="Delete_Click" Tag="{Binding Id}" Margin="0,0,4,0" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#D32F2F" CornerRadius="8" Padding="14,6" Cursor="Hand" x:Name="DeleteBg">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="White" FontSize="11"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="DeleteBg" Property="Background" Value="#E53935"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="{Binding DeleteVisible}"/>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Aktivieren" Style="{StaticResource ActionButton}"
                                        Visibility="{Binding ActivateVisible}" Click="Activate_Click" Tag="{Binding Id}" Margin="0,0,4,0" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</Window>