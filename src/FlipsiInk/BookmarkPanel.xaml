<UserControl x:Class="FlipsiInk.BookmarkPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Background="#252525">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="🔖 Lesezeichen" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
        <Button DockPanel.Dock="Top" x:Name="BtnAddBookmark" Content="+ Lesezeichen hinzufügen"
                Background="#0078D7" Foreground="White" BorderThickness="0" Padding="8,4" Margin="0,0,0,8" Cursor="Hand" FontSize="12"/>
        <ListBox x:Name="BookmarkList" Background="Transparent" Foreground="White" BorderThickness="0"
                 SelectionMode="Single" FontSize="12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="2">
                        <Button DockPanel.Dock="Right" Content="×" FontSize="10" Width="18" Height="18"
                                Background="Transparent" Foreground="#999" BorderThickness="0" Cursor="Hand"
                                Click="RemoveBookmark_Click" Tag="{Binding Id}"/>
                        <TextBlock Text="{Binding Label}" Foreground="White" VerticalAlignment="Center" Cursor="Hand"
                                   MouseLeftButtonUp="Bookmark_Click"/>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>