<Window x:Class="FlipsiInk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlipsiInk"
        Title="FlipsiInk"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Color picker popup items style -->
        <Style x:Key="ColorSwatchButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="14" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Tab Bar (Issue #21) -->
        <local:TabBarControl DockPanel.Dock="Top" x:Name="TabBar" Height="32"/>

        <!-- Top Bar -->
        <DockPanel DockPanel.Dock="Top" Background="#2D2D2D" Height="48" x:Name="TopBar">
            <Border Background="#444" Height="1" DockPanel.Dock="Bottom"/>
            <StackPanel Orientation="Horizontal" Margin="8,0">
                <TextBlock Text="&#x270E; FlipsiInk" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="8,0,16,0" x:Name="AppTitle"/>
                <TextBlock x:Name="VersionLabel" Text="v0.1.0" FontSize="11" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,16,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0">
                <!-- Zoom Controls -->
                <Button x:Name="BtnZoomOut" Content="&#x2212;" Style="{StaticResource ToolButton}" ToolTip="Verkleinern" FontSize="18"/>
                <TextBlock x:Name="ZoomLabel" Text="100%" Foreground="White" VerticalAlignment="Center" FontSize="12" Margin="4,0" Width="45" TextAlignment="Center"/>
                <Button x:Name="BtnZoomIn" Content="&#xFF0B;" Style="{StaticResource ToolButton}" ToolTip="Vergrößern" FontSize="16"/>
                <Button x:Name="BtnZoomReset" Content="&#x22A1;" Style="{StaticResource ToolButton}" ToolTip="Seitengröße"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnUndo" Content="&#x21B6;" Style="{StaticResource ToolButton}" ToolTip="Rückgängig (Ctrl+Z)" FontSize="16"/>
                <Button x:Name="BtnRedo" Content="&#x21B7;" Style="{StaticResource ToolButton}" ToolTip="Wiederholen (Ctrl+Y)" FontSize="16"/>
                <Button x:Name="BtnClear" Content="&#x2715;" Style="{StaticResource ToolButton}" ToolTip="Alles löschen" FontSize="13"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnRecognize" Content="Aa" Style="{StaticResource ToolButton}" ToolTip="Text erkennen (Ctrl+Shift+R)" Background="#0078D7" FontWeight="Bold"/>
                <Button x:Name="BtnCalc" Content="&#x2211;" Style="{StaticResource ToolButton}" ToolTip="Mathe berechnen (Ctrl+Shift+M)" Background="#0078D7" FontSize="16"/>
                <Button x:Name="BtnAutoTidy" Content="&#x203B;" Style="{StaticResource ToolButton}" ToolTip="Auto-Tidy: Layout aufräumen" Background="#0078D7"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnNotebooks" Content="&#x2637;" Style="{StaticResource ToolButton}" ToolTip="Notizbücher"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnSave" Content="&#x25C9;" Style="{StaticResource ToolButton}" ToolTip="Speichern" FontSize="16"/>
                <Button x:Name="BtnExport" Content="&#x2197;" Style="{StaticResource ToolButton}" ToolTip="Export &amp; Teilen (Ctrl+E)" FontSize="16"/>
                <Button x:Name="BtnTheme" Content="&#x25D0;" Style="{StaticResource ToolButton}" ToolTip="Theme wechseln" FontSize="16"/>
                <Button x:Name="BtnLayout" Content="&#x25A3;" Style="{StaticResource ToolButton}" ToolTip="Layout wechseln (Klassisch/Modern)"/>
                <Button x:Name="BtnModelManager" Content="&#x229E;" Style="{StaticResource ToolButton}" ToolTip="KI-Modelle verwalten" FontSize="16"/>
                <Button x:Name="BtnSettings" Content="&#x2699;" Style="{StaticResource ToolButton}" ToolTip="Einstellungen" FontSize="16"/>
                <Button x:Name="BtnCheckUpdate" Content="&#x21BB;" Style="{StaticResource ToolButton}" ToolTip="Nach Update suchen" FontSize="16"/>
                <Separator Margin="4,8"/>
                <ToggleButton x:Name="BtnBookmarks" Content="&#x2606;" Style="{StaticResource ToolButton}" ToolTip="Lesezeichen" FontSize="16"/>
                <ToggleButton x:Name="BtnBacklinks" Content="&#x21E0;" Style="{StaticResource ToolButton}" ToolTip="Rückverweise" FontSize="16"/>
                <Button x:Name="BtnRecentFiles" Content="&#x2630;" Style="{StaticResource ToolButton}" ToolTip="Zuletzt geöffnet" FontSize="14"/>
            </StackPanel>
        </DockPanel>

        <!-- ========== MODERN LAYOUT: Horizontal Toolbar ========== -->
        <Border DockPanel.Dock="Top" Background="#252525" Padding="8,4" CornerRadius="0,0,8,8" x:Name="ModernToolbar" Visibility="Visible">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.3" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <!-- Drawing Tools -->
                <Button x:Name="BtnPen_M" Content="&#x270E;" Style="{StaticResource ToolButton}" ToolTip="Stift" Background="#0078D7" FontSize="16"/>
                <Button x:Name="BtnHighlighter_M" Content="&#x25A4;" Style="{StaticResource ToolButton}" ToolTip="Textmarker"/>
                <Button x:Name="BtnEraser_M" Content="&#x2715;" Style="{StaticResource ToolButton}" ToolTip="Radierer" FontSize="13"/>
                <Button x:Name="BtnSelect_M" Content="&#x261C;" Style="{StaticResource ToolButton}" ToolTip="Auswählen"/>
                <Separator Margin="4,4"/>
                <!-- Shapes -->
                <Button x:Name="BtnLine_M" Content="&#x2500;" Style="{StaticResource ToolButton}" ToolTip="Linie" FontSize="18"/>
                <Button x:Name="BtnRect_M" Content="&#x25A1;" Style="{StaticResource ToolButton}" ToolTip="Rechteck"/>
                <Button x:Name="BtnCircle_M" Content="&#x25CB;" Style="{StaticResource ToolButton}" ToolTip="Kreis"/>
                <Separator Margin="4,4"/>
                <!-- Color Picker (Modern) -->
                <Button x:Name="BtnColorPicker_M" Style="{StaticResource ToolButton}" ToolTip="Farbe wählen" Width="38" Height="38">
                    <Ellipse x:Name="CurrentColorIndicator_M" Width="20" Height="20" Fill="Black" Stroke="#888" StrokeThickness="1"/>
                </Button>
                <Popup x:Name="ColorPopup_M" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnColorPicker_M}" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="10" BorderBrush="#555" BorderThickness="1">
                        <UniformGrid Columns="5" Rows="2">
                            <Button Style="{StaticResource ColorSwatchButton}" Background="Black" Click="ColorSwatch_Click" Tag="Black"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#00008B" Click="ColorSwatch_Click" Tag="DarkBlue"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="Blue" Click="ColorSwatch_Click" Tag="Blue"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="Red" Click="ColorSwatch_Click" Tag="Red"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#008000" Click="ColorSwatch_Click" Tag="Green"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#FF8C00" Click="ColorSwatch_Click" Tag="Orange"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#800080" Click="ColorSwatch_Click" Tag="Purple"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#8B4513" Click="ColorSwatch_Click" Tag="Brown"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="Gray" Click="ColorSwatch_Click" Tag="Gray"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#008080" Click="ColorSwatch_Click" Tag="Teal"/>
                        </UniformGrid>
                    </Border>
                </Popup>
                <Separator Margin="4,4"/>
                <!-- Sizes -->
                <Button x:Name="BtnThin_M" Content="&#x25AA;" Style="{StaticResource ToolButton}" ToolTip="Dünn" FontSize="8"/>
                <Button x:Name="BtnMedium_M" Content="&#x25A0;" Style="{StaticResource ToolButton}" ToolTip="Mittel" FontSize="11"/>
                <Button x:Name="BtnThick_M" Content="&#x2B1B;" Style="{StaticResource ToolButton}" ToolTip="Dick"/>
                <Separator Margin="4,4"/>
                <!-- Template &amp; Input Mode -->
                <ComboBox x:Name="TemplateCombo_M" Width="140" Margin="4,0" ToolTip="Seitenvorlage" Style="{StaticResource DarkComboBox}">
                    <ComboBoxItem Content="Blanko"/>
                    <ComboBoxItem Content="Liniert (breit)" IsSelected="True"/>
                    <ComboBoxItem Content="Liniert (schmal)"/>
                    <ComboBoxItem Content="Kariert (klein)"/>
                    <ComboBoxItem Content="Kariert (mittel)"/>
                    <ComboBoxItem Content="Kariert (groß)"/>
                    <ComboBoxItem Content="Punktiert (klein)"/>
                    <ComboBoxItem Content="Punktiert (mittel)"/>
                    <ComboBoxItem Content="Punktiert (groß)"/>
                    <ComboBoxItem Content="Cornell Notes"/>
                    <ComboBoxItem Content="Isometrisch"/>
                </ComboBox>
                <Button x:Name="BtnAutoTidy_M" Content="&#x203B;" Style="{StaticResource ToolButton}" ToolTip="Auto-Tidy: Layout aufräumen" Background="#0078D7"/>
                <Separator Margin="4,4"/>
                <Button x:Name="BtnInputMode_M" Content="&#x270B;" Style="{StaticResource ToolButton}" ToolTip="Eingabe-Modus: Stift/Touch/Beide"/>
                <Separator Margin="4,4"/>
                <ToggleButton x:Name="BtnStickyNote_M" Content="&#x25AF;" Style="{StaticResource ToolButton}" ToolTip="Klebezettel-Modus"/>
            </StackPanel>
        </Border>

        <!-- ========== CLASSIC LAYOUT: Left Toolbar ========== -->
        <Border DockPanel.Dock="Left" Background="#252525" Width="56" Padding="4" CornerRadius="0,8,8,0" x:Name="LeftToolbar" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.2" Color="Black" Direction="90"/>
            </Border.Effect>
            <StackPanel>
                <Button x:Name="BtnPen" Content="&#x270E;" Style="{StaticResource ToolButton}" ToolTip="Stift" Background="#0078D7" FontSize="16"/>
                <Button x:Name="BtnHighlighter" Content="&#x25A4;" Style="{StaticResource ToolButton}" ToolTip="Textmarker"/>
                <Button x:Name="BtnEraser" Content="&#x2715;" Style="{StaticResource ToolButton}" ToolTip="Radierer" FontSize="13"/>
                <Button x:Name="BtnSelect" Content="&#x261C;" Style="{StaticResource ToolButton}" ToolTip="Auswählen"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnLine" Content="&#x2500;" Style="{StaticResource ToolButton}" ToolTip="Linie" FontSize="18"/>
                <Button x:Name="BtnRect" Content="&#x25A1;" Style="{StaticResource ToolButton}" ToolTip="Rechteck"/>
                <Button x:Name="BtnCircle" Content="&#x25CB;" Style="{StaticResource ToolButton}" ToolTip="Kreis"/>
                <Separator Margin="4,8"/>
                <!-- Color Picker (Classic) -->
                <Button x:Name="BtnColorPicker" Style="{StaticResource ToolButton}" ToolTip="Farbe wählen" Width="38" Height="38">
                    <Ellipse x:Name="CurrentColorIndicator" Width="20" Height="20" Fill="Black" Stroke="#888" StrokeThickness="1"/>
                </Button>
                <Popup x:Name="ColorPopup" Placement="Right" PlacementTarget="{Binding ElementName=BtnColorPicker}" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="10" BorderBrush="#555" BorderThickness="1">
                        <UniformGrid Columns="5" Rows="2">
                            <Button Style="{StaticResource ColorSwatchButton}" Background="Black" Click="ColorSwatch_Click" Tag="Black"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#00008B" Click="ColorSwatch_Click" Tag="DarkBlue"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="Blue" Click="ColorSwatch_Click" Tag="Blue"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="Red" Click="ColorSwatch_Click" Tag="Red"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#008000" Click="ColorSwatch_Click" Tag="Green"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#FF8C00" Click="ColorSwatch_Click" Tag="Orange"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#800080" Click="ColorSwatch_Click" Tag="Purple"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#8B4513" Click="ColorSwatch_Click" Tag="Brown"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="Gray" Click="ColorSwatch_Click" Tag="Gray"/>
                            <Button Style="{StaticResource ColorSwatchButton}" Background="#008080" Click="ColorSwatch_Click" Tag="Teal"/>
                        </UniformGrid>
                    </Border>
                </Popup>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnThin" Content="&#x25AA;" Style="{StaticResource ToolButton}" ToolTip="Dünn" FontSize="8"/>
                <Button x:Name="BtnMedium" Content="&#x25A0;" Style="{StaticResource ToolButton}" ToolTip="Mittel" FontSize="11"/>
                <Button x:Name="BtnThick" Content="&#x2B1B;" Style="{StaticResource ToolButton}" ToolTip="Dick"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnTemplate" Content="&#x25A3;" Style="{StaticResource ToolButton}" ToolTip="Seitenvorlage"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnAutoTidy_C" Content="&#x203B;" Style="{StaticResource ToolButton}" ToolTip="Auto-Tidy: Layout aufräumen"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnInputMode" Content="&#x270B;" Style="{StaticResource ToolButton}" ToolTip="Eingabe-Modus: Stift/Touch/Beide"/>
                <Separator Margin="4,8"/>
                <ToggleButton x:Name="BtnStickyNote" Content="&#x25AF;" Style="{StaticResource ToolButton}" ToolTip="Klebezettel-Modus"/>
            </StackPanel>
        </Border>

        <!-- Left: Page Thumbnail Strip (Issue #15) -->
        <local:PageThumbnailControl x:Name="PageThumbnails" DockPanel.Dock="Left" Width="100"/>

        <!-- Left: Bookmark Panel (Issue #21) -->
        <local:BookmarkPanel x:Name="BookmarkSidebar" DockPanel.Dock="Left" Visibility="Collapsed"/>

        <!-- Left: Backlinks Panel (Issue #33) -->
        <local:BacklinksPanel x:Name="BacklinksSidebar" DockPanel.Dock="Left" Visibility="Collapsed"/>

        <!-- Recent Files Popup (Issue #21) -->
        <Popup x:Name="RecentFilesPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnRecentFiles}" StaysOpen="False" AllowsTransparency="True">
            <Border Background="#2D2D2D" CornerRadius="8" Padding="8" MinWidth="200" MaxHeight="300">
                <StackPanel>
                    <TextBlock Text="Zuletzt geöffnet" FontWeight="Bold" Foreground="White" FontSize="13" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="RecentFilesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Padding="4,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Cursor="Hand" Click="RecentFile_Click" FontSize="12" Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Right Panel: Recognition Results -->
        <Border DockPanel.Dock="Right" Background="#252525" Width="280" Padding="12" CornerRadius="8,0,0,8" x:Name="RightPanel">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="-2" BlurRadius="6" Opacity="0.2" Color="Black" Direction="0"/>
            </Border.Effect>
            <StackPanel>
                <!-- Card: Erkannter Text -->
                <Border Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Erkannter Text" FontWeight="Bold" Foreground="White" FontSize="13" Margin="0,0,0,6"/>
                        <TextBox x:Name="RecognizedText" AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="120" VerticalScrollBarVisibility="Auto"
                                 Background="#252525" Foreground="White" BorderThickness="1" BorderBrush="#444"
                                 FontSize="13" IsReadOnly="True" Padding="6"/>
                    </StackPanel>
                </Border>

                <!-- Card: Mathe-Ergebnis -->
                <Border Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Mathe-Ergebnis" FontWeight="Bold" Foreground="White" FontSize="13" Margin="0,0,0,6"/>
                        <TextBox x:Name="MathResult" AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="80" VerticalScrollBarVisibility="Auto"
                                 Background="#252525" Foreground="#4CAF50" BorderThickness="1" BorderBrush="#444"
                                 FontSize="15" FontWeight="Bold" IsReadOnly="True" Padding="6"/>
                    </StackPanel>
                </Border>

                <!-- Card: Status -->
                <Border Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Status" FontWeight="Bold" Foreground="White" FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock x:Name="StatusText" Text="Bereit" Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
                        <TextBlock x:Name="PageIndicator" Text="Seite 1/1" Foreground="#0078D7" FontWeight="Bold" FontSize="12" Margin="0,6,0,0"/>
                        <TextBlock x:Name="ModelStatus" Text="Modell: nicht geladen" Foreground="#FF6600" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Smart-Detection Links (Issue #30) -->
                <Border x:Name="SmartLinksCard" Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,0,0,8" Visibility="Collapsed">
                    <StackPanel x:Name="SmartLinksPanel">
                        <TextBlock Text="Erkannte Links" FontWeight="Bold" Foreground="White" FontSize="13" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="SmartLinksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,2">
                                        <Hyperlink NavigateUri="{Binding Uri}" RequestNavigate="SmartLink_Navigate" Foreground="#4CAF50">
                                            <Run Text="{Binding Label}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Suche-Button (Issue #30) -->
                <Button x:Name="BtnSearch" Content="&#x2630; Notizen durchsuchen" Style="{StaticResource ToolButton}" ToolTip="Volltextsuche in gespeicherten Notizen" Margin="0,4,0,0" HorizontalAlignment="Stretch"/>

                <!-- Template Preview (Classic only) -->
                <StackPanel x:Name="ClassicTemplatePanel" Visibility="Collapsed">
                    <Border Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Vorlage" FontWeight="Bold" Foreground="White" FontSize="13" Margin="0,0,0,6"/>
                            <ComboBox x:Name="TemplateCombo" Margin="0,0,0,4" Style="{StaticResource DarkComboBox}">
                                <ComboBoxItem Content="Blanko"/>
                                <ComboBoxItem Content="Liniert (breit)" IsSelected="True"/>
                                <ComboBoxItem Content="Liniert (schmal)"/>
                                <ComboBoxItem Content="Kariert (klein)"/>
                                <ComboBoxItem Content="Kariert (mittel)"/>
                                <ComboBoxItem Content="Kariert (groß)"/>
                                <ComboBoxItem Content="Punktiert (klein)"/>
                                <ComboBoxItem Content="Punktiert (mittel)"/>
                                <ComboBoxItem Content="Punktiert (groß)"/>
                                <ComboBoxItem Content="Cornell Notes"/>
                                <ComboBoxItem Content="Isometrisch"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Canvas Area with Zoom -->
        <ScrollViewer x:Name="CanvasScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#1A1A1A">
            <Grid x:Name="CanvasGrid">
                <InkCanvas x:Name="MainCanvas" Background="White" Width="1200" Height="1600"/>
                <!-- Sticky Note overlay (floats above ink strokes) -->
                <Canvas x:Name="StickyNoteOverlay" Width="1200" Height="1600" Background="{x:Null}" ClipToBounds="True"/>
                <!-- Kontext-sensitive Aktionsleiste (Issue #35) -->
                <Popup x:Name="ContextActionPopup" Placement="Relative" PlacementTarget="{Binding ElementName=CanvasGrid}" AllowsTransparency="True" StaysOpen="False">
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="6,3" BorderBrush="#0078D7" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" x:Name="ContextActionPanel"/>
                    </Border>
                </Popup>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>