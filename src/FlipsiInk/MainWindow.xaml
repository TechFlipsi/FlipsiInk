<Window x:Class="FlipsiInk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlipsiInk"
        Title="FlipsiInk"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <!-- Color picker popup items style -->
        <Style x:Key="ColorSwatchButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="14" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- ═══════════════════════════════════════════════════════
             LAYER 0: Main Content (Canvas + Panels)
             ═══════════════════════════════════════════════════════ -->
        <DockPanel x:Name="MainDock">

            <!-- Tab Bar (thin, minimal) -->
            <local:TabBarControl DockPanel.Dock="Top" x:Name="TabBar" Height="32"/>

            <!-- ═══ MINIMAL TOP BAR ═══ -->
            <DockPanel DockPanel.Dock="Top" Background="#1A1A1A" Height="36" x:Name="TopBar">
                <Border Background="#333" Height="1" DockPanel.Dock="Bottom" Opacity="0.5"/>
                <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                    <TextBlock Text="FlipsiInk" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" Margin="4,0,12,0" x:Name="AppTitle" Opacity="0.8"/>
                    <TextBlock x:Name="VersionLabel" Text="v0.4.0" FontSize="10" Foreground="#666" VerticalAlignment="Center" Margin="0,0,12,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0" VerticalAlignment="Center">
                    <!-- Zoom -->
                    <Button x:Name="BtnZoomOut" Content="&#x2212;" Style="{StaticResource ToolButton}" ToolTip="Verkleinern" FontSize="16" Width="36" Height="36"/>
                    <TextBlock x:Name="ZoomLabel" Text="100%" Foreground="#999" VerticalAlignment="Center" FontSize="11" Margin="4,0" Width="40" TextAlignment="Center"/>
                    <Button x:Name="BtnZoomIn" Content="&#xFF0B;" Style="{StaticResource ToolButton}" ToolTip="Vergr&#xF6;&#xDF;ern" FontSize="14" Width="36" Height="36"/>
                    <Button x:Name="BtnZoomReset" Content="&#x22A1;" Style="{StaticResource ToolButton}" ToolTip="Seitengr&#xF6;&#xDF;e" Width="36" Height="36"/>
                    <Separator Margin="4,4" Background="#333"/>
                    <!-- Undo/Redo -->
                    <Button x:Name="BtnUndo" Content="&#x21B6;" Style="{StaticResource ToolButton}" ToolTip="R&#xFC;ckg&#xE4;ngig (Ctrl+Z)" FontSize="14" Width="36" Height="36"/>
                    <Button x:Name="BtnRedo" Content="&#x21B7;" Style="{StaticResource ToolButton}" ToolTip="Wiederholen (Ctrl+Y)" FontSize="14" Width="36" Height="36"/>
                    <Separator Margin="4,4" Background="#333"/>
                    <!-- Actions -->
                    <Button x:Name="BtnNotebooks" Content="&#x2637;" Style="{StaticResource ToolButton}" ToolTip="Notizb&#xFC;cher" Width="36" Height="36"/>
                    <Button x:Name="BtnSave" Content="&#x25C9;" Style="{StaticResource ToolButton}" ToolTip="Speichern" FontSize="14" Width="36" Height="36"/>
                    <Button x:Name="BtnImportPdf" Content="PDF" Style="{StaticResource ToolButton}" ToolTip="PDF importieren" FontSize="10" FontWeight="Bold" Width="36" Height="36" Click="ImportPdf"/>
                    <Button x:Name="BtnExport" Content="&#x2197;" Style="{StaticResource ToolButton}" ToolTip="Export &amp; Teilen (Ctrl+E)" FontSize="14" Width="36" Height="36"/>
                    <Separator Margin="4,4" Background="#333"/>
                    <Button x:Name="BtnTheme" Content="&#x25D0;" Style="{StaticResource ToolButton}" ToolTip="Theme wechseln" FontSize="14" Width="36" Height="36"/>
                    <Button x:Name="BtnModelManager" Content="&#x229E;" Style="{StaticResource ToolButton}" ToolTip="KI-Modelle verwalten" FontSize="14" Width="36" Height="36"/>
                    <Button x:Name="BtnSettings" Content="&#x2699;" Style="{StaticResource ToolButton}" ToolTip="Einstellungen" FontSize="14" Width="36" Height="36"/>
                    <Button x:Name="BtnCheckUpdate" Content="&#x21BB;" Style="{StaticResource ToolButton}" ToolTip="Nach Update suchen" FontSize="14" Width="36" Height="36"/>
                    <Separator Margin="4,4" Background="#333"/>
                    <ToggleButton x:Name="BtnBookmarks" Content="&#x2606;" Style="{StaticResource ToolButton}" ToolTip="Lesezeichen" FontSize="14" Width="36" Height="36"/>
                    <ToggleButton x:Name="BtnBacklinks" Content="&#x21E0;" Style="{StaticResource ToolButton}" ToolTip="R&#xFC;ckverweise" FontSize="14" Width="36" Height="36"/>
                    <Button x:Name="BtnRecentFiles" Content="&#x2630;" Style="{StaticResource ToolButton}" ToolTip="Zuletzt ge&#xF6;ffnet" FontSize="12" Width="36" Height="36"/>
                </StackPanel>
            </DockPanel>

            <!-- ═══ STATUS BAR (bottom, minimal) ═══ -->
            <DockPanel DockPanel.Dock="Bottom" Background="#1A1A1A" Height="24" x:Name="BottomBar">
                <Border Background="#333" Height="1" DockPanel.Dock="Top" Opacity="0.5"/>
                <TextBlock x:Name="StatusText" Text="Bereit" Foreground="#666" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="PageIndicator" Text="Seite 1/1" Foreground="#0078D7" FontWeight="SemiBold" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <TextBlock x:Name="ModelStatus" Text="" Foreground="#666" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>

            <!-- ═══ LEFT: Backlinks Panel (slide-in) ═══ -->
            <local:BacklinksPanel x:Name="BacklinksSidebar" DockPanel.Dock="Left" Visibility="Collapsed"/>
            <local:BookmarkPanel x:Name="BookmarkSidebar" DockPanel.Dock="Left" Visibility="Collapsed"/>

            <!-- ═══ RIGHT: Recognition Results Panel (slide-in, toggleable) ═══ -->
            <Border DockPanel.Dock="Right" Background="#1E1E1E" Width="260" CornerRadius="12,0,0,12" x:Name="RightPanel" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="-3" BlurRadius="12" Opacity="0.3" Color="Black" Direction="0"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <!-- Toggle button for right panel -->
                        <Button x:Name="BtnCloseRightPanel" Content="&#x25B6;" HorizontalAlignment="Right" Style="{StaticResource ToolButton}" ToolTip="Panel schlie&#xDF;en" Width="24" Height="24" FontSize="10"/>

                        <!-- Card: Erkannter Text -->
                        <Border Background="#2A2A2A" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Erkannter Text" FontWeight="SemiBold" Foreground="White" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox x:Name="RecognizedText" AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="100" VerticalScrollBarVisibility="Auto"
                                         Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#3A3A3A"
                                         FontSize="12" IsReadOnly="True" Padding="6"/>
                                <Button x:Name="BtnExportRecognizedText" Content="Text exportieren..." 
                                        HorizontalAlignment="Right" Margin="0,6,0,0"
                                        Style="{StaticResource AccentButton}" FontSize="11"
                                        Click="BtnExportRecognizedText_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Card: Mathe-Ergebnis -->
                        <Border Background="#2A2A2A" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Mathe-Ergebnis" FontWeight="SemiBold" Foreground="White" FontSize="12" Margin="0,0,0,6"/>
                                <TextBox x:Name="MathResult" AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="60" VerticalScrollBarVisibility="Auto"
                                         Background="#1E1E1E" Foreground="#4CAF50" BorderThickness="1" BorderBrush="#3A3A3A"
                                         FontSize="14" FontWeight="Bold" IsReadOnly="True" Padding="6"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                    <Button x:Name="BtnCopyLatex" Content="∑ LaTeX" Style="{StaticResource ToolButton}" 
                                            ToolTip="LaTeX in Zwischenablage kopieren" FontSize="10" Width="60" Height="24" 
                                            Click="BtnCopyLatex_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Card: Smart-Detection Links -->
                        <Border x:Name="SmartLinksCard" Background="#2A2A2A" CornerRadius="10" Padding="10" Margin="0,0,0,8" Visibility="Collapsed">
                            <StackPanel x:Name="SmartLinksPanel">
                                <TextBlock Text="Erkannte Links" FontWeight="SemiBold" Foreground="White" FontSize="12" Margin="0,0,0,4"/>
                                <ItemsControl x:Name="SmartLinksList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,2">
                                                <Hyperlink NavigateUri="{Binding Uri}" RequestNavigate="SmartLink_Navigate" Foreground="#4CAF50">
                                                    <Run Text="{Binding Label}"/>
                                                </Hyperlink>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Search -->
                        <Button x:Name="BtnSearch" Content="&#x2630; Notizen durchsuchen" Style="{StaticResource ToolButton}" ToolTip="Volltextsuche" Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Recent Files Popup -->
            <Popup x:Name="RecentFilesPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnRecentFiles}" StaysOpen="False" AllowsTransparency="True">
                <Border Background="#2A2A2A" CornerRadius="10" Padding="10" MinWidth="200" MaxHeight="300">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.4" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Zuletzt ge&#xF6;ffnet" FontWeight="SemiBold" Foreground="White" FontSize="12" Margin="0,0,0,6"/>
                        <ItemsControl x:Name="RecentFilesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Padding="4,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Cursor="Hand" Click="RecentFile_Click" FontSize="12" Margin="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- ═══ MAIN CANVAS AREA ═══ -->
            <ScrollViewer x:Name="CanvasScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                <Grid x:Name="CanvasGrid">
                    <Image x:Name="CanvasBackgroundImage" Stretch="Uniform" Visibility="Collapsed"/>
                    <InkCanvas x:Name="MainCanvas" Background="White" Width="1200" Height="1600"/>
                    <!-- Sticky Note overlay -->
                    <Canvas x:Name="StickyNoteOverlay" Width="1200" Height="1600" Background="{x:Null}" ClipToBounds="True"/>
                    <!-- Context-sensitive action popup (Nebo-style) -->
                    <Popup x:Name="ContextActionPopup" Placement="Relative" PlacementTarget="{Binding ElementName=CanvasGrid}" AllowsTransparency="True" StaysOpen="False">
                        <Border Background="#2A2A2A" CornerRadius="10" Padding="6,4" BorderBrush="#0078D7" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.3" Color="Black"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal" x:Name="ContextActionPanel"/>
                        </Border>
                    </Popup>
                </Grid>
            </ScrollViewer>
        </DockPanel>

        <!-- ═══════════════════════════════════════════════════════
             LAYER 1: Floating Pill Toolbar (OVERLAY on canvas)
             Notewise-inspired: minimal, grouped tools, expandable sub-toolbars.
             Original design — no copyrighted assets or code.
             ═══════════════════════════════════════════════════════ -->
        <Border x:Name="FloatingToolbar" 
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Background="#DD252525" 
                CornerRadius="20"
                Padding="8,4"
                Margin="150,0,0,0"
                MouseLeftButtonDown="FloatingToolbar_MouseLeftButtonDown"
                MouseLeftButtonUp="FloatingToolbar_MouseLeftButtonUp"
                MouseMove="FloatingToolbar_MouseMove"
                Cursor="SizeAll"
                Visibility="Visible">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.4" Color="Black"/>
            </Border.Effect>
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Oben andocken" Click="DockToolbarTop"/>
                    <MenuItem Header="Links andocken" Click="DockToolbarLeft"/>
                    <MenuItem Header="Rechts andocken" Click="DockToolbarRight"/>
                    <Separator/>
                    <MenuItem Header="Toolbar zur&#xFC;cksetzen" Click="ResetToolbarPosition"/>
                </ContextMenu>
            </Border.ContextMenu>
            <StackPanel Orientation="Horizontal" x:Name="FloatingToolbarContent">
                <!-- Drag Handle indicator -->
                <TextBlock Text="&#x2807;" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="0,0,4,0"/>

                <!-- ═══ PEN GROUP: Stift + Unterwerkzeuge ═══ -->
                <StackPanel Orientation="Horizontal" x:Name="PenGroup">
                    <Button x:Name="BtnPen_F" Content="&#x270E;" Style="{StaticResource PillToolButtonActive}" ToolTip="Stift" Click="BtnPen_F_Click"/>
                    <!-- Pen sub-types (shown on long-press or dropdown) -->
                    <Popup x:Name="PenSubtypePopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnPen_F}" StaysOpen="True" AllowsTransparency="True">
                        <Border Background="#2A2A2A" CornerRadius="10" Padding="8" BorderBrush="#0078D7" BorderThickness="1">
                            <Border.Effect><DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/></Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Stift-Typ" Foreground="#CCC" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Button x:Name="BtnPenFineliner" Content="&#x270E; Fineliner" Style="{StaticResource ToolButton}" ToolTip="Fineliner — dünner, präziser Strich" Click="BtnPenFineliner_Click" HorizontalAlignment="Stretch" Width="140"/>
                                <Button x:Name="BtnPenFountain" Content="&#x270E; Füller" Style="{StaticResource ToolButton}" ToolTip="Füller — variabler Strich mit Druck" Click="BtnPenFountain_Click" HorizontalAlignment="Stretch" Width="140"/>
                                <Button x:Name="BtnPenPencil" Content="&#x270E; Bleistift" Style="{StaticResource ToolButton}" ToolTip="Bleistift — weicher, breiter Strich" Click="BtnPenPencil_Click" HorizontalAlignment="Stretch" Width="140"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <!-- ═══ MARKER GROUP ═══ -->
                <Button x:Name="BtnHighlighter_F" Content="&#x25A4;" Style="{StaticResource PillToolButton}" ToolTip="Textmarker" Click="BtnHighlighter_F_Click"/>
                
                <!-- ═══ ERASER GROUP ═══ -->
                <Button x:Name="BtnEraser_F" Content="&#x2715;" Style="{StaticResource PillToolButton}" ToolTip="Radierer" Click="BtnEraser_F_Click"/>

                <!-- ═══ SELECTION GROUP ═══ -->
                <Button x:Name="BtnSelect_F" Content="&#x261C;" Style="{StaticResource PillToolButton}" ToolTip="Lasso / Ausw&#xE4;hlen" Click="BtnSelect_F_Click"/>

                <!-- ═══ SHAPE GROUP ═══ -->
                <Button x:Name="BtnShape_F" Content="&#x25B3;" Style="{StaticResource PillToolButton}" ToolTip="Formen" Click="BtnShape_F_Click"/>
                <Popup x:Name="ShapeSubtypePopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnShape_F}" StaysOpen="True" AllowsTransparency="True">
                    <Border Background="#2A2A2A" CornerRadius="10" Padding="8" BorderBrush="#0078D7" BorderThickness="1">
                        <Border.Effect><DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Formen" Foreground="#CCC" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <UniformGrid Columns="3" Rows="2">
                                <Button x:Name="BtnShapeLine"     Content="&#x2500;" Style="{StaticResource ToolButton}" ToolTip="Linie"         Click="BtnShapeLine_Click"     Width="40" Height="40" FontSize="18"/>
                                <Button x:Name="BtnShapeArrow"    Content="&#x2192;" Style="{StaticResource ToolButton}" ToolTip="Pfeil"          Click="BtnShapeArrow_Click"    Width="40" Height="40" FontSize="18"/>
                                <Button x:Name="BtnShapeRect"     Content="&#x25A1;" Style="{StaticResource ToolButton}" ToolTip="Rechteck"      Click="BtnShapeRect_Click"     Width="40" Height="40" FontSize="18"/>
                                <Button x:Name="BtnShapeCircle"   Content="&#x25CB;" Style="{StaticResource ToolButton}" ToolTip="Kreis"         Click="BtnShapeCircle_Click"   Width="40" Height="40" FontSize="18"/>
                                <Button x:Name="BtnShapeTriangle" Content="&#x25B3;" Style="{StaticResource ToolButton}" ToolTip="Dreieck"       Click="BtnShapeTriangle_Click" Width="40" Height="40" FontSize="18"/>
                                <Button x:Name="BtnShapeFree"     Content="&#x270E;" Style="{StaticResource ToolButton}" ToolTip="Freihand"      Click="BtnShapeFree_Click"     Width="40" Height="40" FontSize="14"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- ═══ SCRATCH-TO-ERASE ═══ -->
                <ToggleButton x:Name="BtnScratchErase" Content="&#x232B;" Style="{StaticResource PillToolButton}" ToolTip="Durchstreichen l&#xF6;scht" IsChecked="False"/>

                <!-- ═══ TEXT TOOL ═══ -->
                <Button x:Name="BtnText_F" Content="Aa" Style="{StaticResource PillToolButton}" ToolTip="Text-Werkzeug" Click="BtnText_F_Click" FontWeight="Bold" FontSize="12"/>
                
                <!-- Separator -->
                <Border Width="1" Background="#444" Margin="4,4"/>
                
                <!-- ═══ COLOR PALETTE (Notewise-style expandable) ═══ -->
                <Border x:Name="QuickColorPanel" Background="#181818" CornerRadius="10" Padding="6,2" Margin="2,0">
                    <StackPanel Orientation="Horizontal">
                        <!-- 5 Quick Color Dots -->
                        <Ellipse x:Name="QuickColor1" Width="22" Height="22" Fill="Black" Stroke="#555" StrokeThickness="1" Cursor="Hand" MouseLeftButtonUp="QuickColor1_Click" Margin="0,0,3,0" ToolTip="Farbe 1"/>
                        <Ellipse x:Name="QuickColor2" Width="22" Height="22" Fill="#00008B" Stroke="#555" StrokeThickness="1" Cursor="Hand" MouseLeftButtonUp="QuickColor2_Click" Margin="0,0,3,0" ToolTip="Farbe 2"/>
                        <Ellipse x:Name="QuickColor3" Width="22" Height="22" Fill="Red" Stroke="#555" StrokeThickness="1" Cursor="Hand" MouseLeftButtonUp="QuickColor3_Click" Margin="0,0,3,0" ToolTip="Farbe 3"/>
                        <Ellipse x:Name="QuickColor4" Width="22" Height="22" Fill="#0078D7" Stroke="#555" StrokeThickness="1" Cursor="Hand" MouseLeftButtonUp="QuickColor4_Click" Margin="0,0,3,0" ToolTip="Farbe 4"/>
                        <Ellipse x:Name="QuickColor5" Width="22" Height="22" Fill="#008000" Stroke="#555" StrokeThickness="1" Cursor="Hand" MouseLeftButtonUp="QuickColor5_Click" ToolTip="Farbe 5"/>
                        <!-- Current color indicator + picker -->
                        <Button x:Name="BtnColorPicker_F" Style="{StaticResource PillToolButton}" ToolTip="Farbe w&#xE4;hlen" Width="32" Height="32" Margin="3,0,0,0" Click="BtnColorPicker_F_Click">
                            <Ellipse x:Name="CurrentColorIndicator_F" Width="18" Height="18" Fill="Black" Stroke="#888" StrokeThickness="1"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ═══ SIZE SLIDER (Notewise-style) ═══ -->
                <Border x:Name="QuickSizePanel" Background="#181818" CornerRadius="10" Padding="8,4" Margin="2,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x25CF;" FontSize="8" Foreground="#999" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Slider x:Name="PenSizeSlider" Minimum="0.5" Maximum="20" Value="2.5" Width="80" 
                                Background="#333" Foreground="#0078D7" 
                                ToolTip="Stiftst&#xE4;rke"
                                ValueChanged="PenSizeSlider_ValueChanged"/>
                        <TextBlock Text="&#x25CF;" FontSize="18" Foreground="#999" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border Width="1" Background="#444" Margin="4,4"/>

                <!-- ═══ SMART FEATURES ═══ -->
                <!-- Shape Recognition Toggle -->
                <ToggleButton x:Name="BtnShapeRecognition" Content="&#x2714;" Style="{StaticResource PillToolButton}" ToolTip="Formerkennung ein/aus" IsChecked="True" FontSize="14" Click="BtnShapeRecognition_Click"/>
                
                <!-- AI Recognition -->
                <Button x:Name="BtnRecognize_F" Content="&#x1F916;" Style="{StaticResource PillToolButton}" ToolTip="KI-Erkennung starten" Click="BtnRecognize_F_Click" FontSize="14"/>
                
                <!-- Template combo -->
                <ComboBox x:Name="TemplateCombo_F" Width="110" Margin="4,0" ToolTip="Seitenvorlage" Style="{StaticResource DarkComboBox}" FontSize="11" SelectionChanged="TemplateCombo_SelectionChanged">
                    <ComboBoxItem Content="Blanko"/>
                    <ComboBoxItem Content="Liniert (breit)" IsSelected="True"/>
                    <ComboBoxItem Content="Liniert (schmal)"/>
                    <ComboBoxItem Content="Kariert (klein)"/>
                    <ComboBoxItem Content="Kariert (mittel)"/>
                    <ComboBoxItem Content="Kariert (gro&#xDF;)"/>
                    <ComboBoxItem Content="Punktiert (klein)"/>
                    <ComboBoxItem Content="Punktiert (mittel)"/>
                    <ComboBoxItem Content="Punktiert (gro&#xDF;)"/>
                    <ComboBoxItem Content="Cornell Notes"/>
                    <ComboBoxItem Content="Isometrisch"/>
                </ComboBox>

                <!-- Input Mode -->
                <Button x:Name="BtnInputMode_F" Content="&#x270B;" Style="{StaticResource PillToolButton}" ToolTip="Eingabe-Modus" Click="BtnInputMode_F_Click"/>
                <!-- Sticky Note -->
                <ToggleButton x:Name="BtnStickyNote_F" Content="&#x25AF;" Style="{StaticResource PillToolButton}" ToolTip="Klebezettel-Modus"/>
            </StackPanel>
        </Border>

        <!-- Color Picker Popup (for floating toolbar) -->
        <Popup x:Name="ColorPopup_F" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnColorPicker_F}" StaysOpen="False" AllowsTransparency="True">
            <Border Background="#2A2A2A" CornerRadius="10" Padding="10" BorderBrush="#3A3A3A" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Farbe wählen" Foreground="#CCC" FontSize="11" Margin="0,0,0,6"/>
                    <UniformGrid Columns="5" Rows="4">
                        <Button Style="{StaticResource ColorSwatchButton}" Background="Black" Click="ColorSwatch_Click" Tag="Black"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#00008B" Click="ColorSwatch_Click" Tag="DarkBlue"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="Blue" Click="ColorSwatch_Click" Tag="Blue"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#4169E1" Click="ColorSwatch_Click" Tag="RoyalBlue"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#1E90FF" Click="ColorSwatch_Click" Tag="DodgerBlue"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="Red" Click="ColorSwatch_Click" Tag="Red"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#DC143C" Click="ColorSwatch_Click" Tag="Crimson"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#FF6347" Click="ColorSwatch_Click" Tag="Tomato"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#008000" Click="ColorSwatch_Click" Tag="Green"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#2E8B57" Click="ColorSwatch_Click" Tag="SeaGreen"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#FF8C00" Click="ColorSwatch_Click" Tag="Orange"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#FFD700" Click="ColorSwatch_Click" Tag="Gold"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#800080" Click="ColorSwatch_Click" Tag="Purple"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#DA70D6" Click="ColorSwatch_Click" Tag="Orchid"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#8B4513" Click="ColorSwatch_Click" Tag="Brown"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="Gray" Click="ColorSwatch_Click" Tag="Gray"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#008080" Click="ColorSwatch_Click" Tag="Teal"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#FF69B4" Click="ColorSwatch_Click" Tag="HotPink"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="#808000" Click="ColorSwatch_Click" Tag="Olive"/>
                        <Button Style="{StaticResource ColorSwatchButton}" Background="White" Click="ColorSwatch_Click" Tag="White" BorderBrush="#888"/>
                    </UniformGrid>
                    <Button x:Name="BtnCustomColor_F" Content="Benutzerdefiniert..." Click="BtnCustomColor_Click" Foreground="#CCC" Background="#333" BorderBrush="#555" BorderThickness="1" Padding="4,6" Margin="0,6,0,0" FontSize="11" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ═══════════════════════════════════════════════════════
             LAYER 2: Zen Mode Overlay Button (bottom-left)
             ═══════════════════════════════════════════════════════ -->
        <Button x:Name="BtnZenMode" Content="&#x25D1;" 
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="12,0,0,36"
                Width="32" Height="32"
                Style="{StaticResource ToolButton}"
                ToolTip="Zen-Modus: Alle UI ausblenden"
                Click="ToggleZenMode" FontSize="16"/>

        <!-- ═══════════════════════════════════════════════════════
             LAYER 3: Right Panel Toggle (when hidden)
             ═══════════════════════════════════════════════════════ -->
        <Button x:Name="BtnShowRightPanel" Content="&#x25C0;" 
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,40,4,0"
                Width="24" Height="24"
                Style="{StaticResource ToolButton}"
                ToolTip="Erkennungsergebnisse anzeigen"
                Click="ShowRightPanel" FontSize="10" Visibility="Collapsed"/>

        <!-- ═══════════════════════════════════════════════════════
             LAYER 4: Page Navigation Button (bottom-right)
             ═══════════════════════════════════════════════════════ -->
        <Button x:Name="BtnPageNav" Content="&#x2261;" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,12,36"
                Width="36" Height="36"
                Style="{StaticResource ToolButton}"
                ToolTip="Seitennavigation"
                Click="TogglePageNavPanel" FontSize="18"/>

        <!-- Page Navigation Overlay Panel -->
        <Border x:Name="PageNavOverlay" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="#DD1E1E1E" CornerRadius="12"
                Width="200" Margin="0,0,12,76"
                Visibility="Collapsed" Padding="12">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="-2" BlurRadius="12" Opacity="0.4" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Seiten" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                <local:PageThumbnailControl x:Name="PageThumbnails"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button x:Name="BtnPrevPage" Content="&#x25C0;" Style="{StaticResource ToolButton}" ToolTip="Vorherige Seite" Width="36" Height="36" Click="PrevPage_Click"/>
                    <TextBlock x:Name="PageNavIndicator" Text="1/1" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
                    <Button x:Name="BtnNextPage" Content="&#x25B6;" Style="{StaticResource ToolButton}" ToolTip="N&#xE4;chste Seite" Width="36" Height="36" Click="NextPage_Click"/>
                    <Button x:Name="BtnAddPage" Content="&#x2295;" Style="{StaticResource ToolButton}" ToolTip="Neue Seite" Width="36" Height="36" Click="AddPageFromNav_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             PAGE OVERVIEW PANEL (v0.4.0)
             Slide-in panel with thumbnail grid + page flags
             ═══════════════════════════════════════════════════════ -->
        <Border x:Name="PageOverviewPanel"
                HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Background="#1A1A1A" Width="280" CornerRadius="12,0,0,12"
                Visibility="Collapsed" Margin="0,36,0,24"
                BorderBrush="#333" BorderThickness="1,0,0,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="-4" BlurRadius="16" Opacity="0.4" Color="Black" Direction="0"/>
            </Border.Effect>
            <local:PageOverviewControl x:Name="PageOverview"/>
        </Border>

        <!-- Page Overview toggle button (bottom-right, above page nav) -->
        <Button x:Name="BtnPageOverview" Content="&#x29C9;"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,12,64"
                Width="36" Height="36"
                Style="{StaticResource ToolButton}"
                ToolTip="Seitenübersicht"
                Click="TogglePageOverview" FontSize="16" FontWeight="Bold"/>

        <!-- ═══════════════════════════════════════════════════════
             LAYER 5: Smart Context Popup (Nebo-style)
             Appears near lasso selection with Aa / Sum / Cut
             ═══════════════════════════════════════════════════════ -->
        <Popup x:Name="SmartContextPopup" Placement="Relative" PlacementTarget="{Binding ElementName=CanvasGrid}" AllowsTransparency="True" StaysOpen="False">
            <Border Background="#DD2A2A2A" CornerRadius="12" Padding="6,4">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnContextToText" Content="Aa" Style="{StaticResource PillToolButton}" ToolTip="In Text umwandeln" FontSize="11" FontWeight="Bold" Click="ContextToText_Click"/>
                    <Button x:Name="BtnContextCalc" Content="&#x2211;" Style="{StaticResource PillToolButton}" ToolTip="Berechnen" FontSize="14" Click="ContextToCalc_Click"/>
                    <Button x:Name="BtnContextCut" Content="&#x2702;" Style="{StaticResource PillToolButton}" ToolTip="Ausschneiden" FontSize="12" Click="ContextToCut_Click"/>
                    <Button x:Name="BtnContextCopy" Content="&#x2398;" Style="{StaticResource PillToolButton}" ToolTip="Kopieren" FontSize="12" Click="ContextToCopy_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ═══ Hidden Legacy Elements (kept for code-behind compatibility) ═══ -->
        <!-- These are hidden but exist so code references don't break -->
        <Button x:Name="BtnPen" Visibility="Collapsed"/>
        <Button x:Name="BtnHighlighter" Visibility="Collapsed"/>
        <Button x:Name="BtnEraser" Visibility="Collapsed"/>
        <Button x:Name="BtnSelect" Visibility="Collapsed"/>
        <Button x:Name="BtnLine" Visibility="Collapsed"/>
        <Button x:Name="BtnRect" Visibility="Collapsed"/>
        <Button x:Name="BtnCircle" Visibility="Collapsed"/>
        <Button x:Name="BtnColorPicker" Visibility="Collapsed"/>
        <Popup x:Name="ColorPopup" AllowsTransparency="True" StaysOpen="False" Placement="Bottom">
            <Border Background="#2A2A2A" CornerRadius="10" Padding="10" BorderBrush="#3A3A3A" BorderThickness="1">
                <UniformGrid Columns="5" Rows="4">
                    <Button Style="{StaticResource ColorSwatchButton}" Background="Black" Click="ColorSwatch_Click" Tag="Black"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#00008B" Click="ColorSwatch_Click" Tag="DarkBlue"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="Blue" Click="ColorSwatch_Click" Tag="Blue"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#4169E1" Click="ColorSwatch_Click" Tag="RoyalBlue"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#1E90FF" Click="ColorSwatch_Click" Tag="DodgerBlue"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="Red" Click="ColorSwatch_Click" Tag="Red"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#DC143C" Click="ColorSwatch_Click" Tag="Crimson"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#FF6347" Click="ColorSwatch_Click" Tag="Tomato"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#008000" Click="ColorSwatch_Click" Tag="Green"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#2E8B57" Click="ColorSwatch_Click" Tag="SeaGreen"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#FF8C00" Click="ColorSwatch_Click" Tag="Orange"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#FFD700" Click="ColorSwatch_Click" Tag="Gold"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#800080" Click="ColorSwatch_Click" Tag="Purple"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#DA70D6" Click="ColorSwatch_Click" Tag="Orchid"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#8B4513" Click="ColorSwatch_Click" Tag="Brown"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="Gray" Click="ColorSwatch_Click" Tag="Gray"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#008080" Click="ColorSwatch_Click" Tag="Teal"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#FF69B4" Click="ColorSwatch_Click" Tag="HotPink"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="#808000" Click="ColorSwatch_Click" Tag="Olive"/>
                    <Button Style="{StaticResource ColorSwatchButton}" Background="White" Click="ColorSwatch_Click" Tag="White" BorderBrush="#888"/>
                </UniformGrid>
            </Border>
        </Popup>
        <Ellipse x:Name="CurrentColorIndicator" Width="20" Height="20" Fill="Black" Stroke="#888" StrokeThickness="1" Visibility="Collapsed"/>
        <Button x:Name="BtnThin" Visibility="Collapsed"/>
        <Button x:Name="BtnMedium" Visibility="Collapsed"/>
        <Button x:Name="BtnThick" Visibility="Collapsed"/>
        <Button x:Name="BtnTemplate" Visibility="Collapsed"/>
        <Button x:Name="BtnAutoTidy_C" Visibility="Collapsed"/>
        <Button x:Name="BtnStickyNote" Visibility="Collapsed"/>
        <ToggleButton x:Name="BtnStickyNote_M" Visibility="Collapsed"/>
        <ComboBox x:Name="TemplateCombo" Visibility="Collapsed"/>
        <ComboBox x:Name="TemplateCombo_M" Visibility="Collapsed"/>
        <Button x:Name="BtnPen_M" Visibility="Collapsed"/>
        <Button x:Name="BtnHighlighter_M" Visibility="Collapsed"/>
        <Button x:Name="BtnEraser_M" Visibility="Collapsed"/>
        <Button x:Name="BtnSelect_M" Visibility="Collapsed"/>
        <Button x:Name="BtnLine_M" Visibility="Collapsed"/>
        <Button x:Name="BtnRect_M" Visibility="Collapsed"/>
        <Button x:Name="BtnCircle_M" Visibility="Collapsed"/>
        <Button x:Name="BtnColorPicker_M" Visibility="Collapsed"/>
        <Ellipse x:Name="CurrentColorIndicator_M" Width="20" Height="20" Fill="Black" Stroke="#888" StrokeThickness="1" Visibility="Collapsed"/>
        <Popup x:Name="ColorPopup_M" AllowsTransparency="True" StaysOpen="False" Placement="Bottom"/>
        <Button x:Name="BtnThin_M" Visibility="Collapsed"/>
        <Button x:Name="BtnMedium_M" Visibility="Collapsed"/>
        <Button x:Name="BtnThick_M" Visibility="Collapsed"/>
        <Button x:Name="BtnAutoTidy_M" Visibility="Collapsed"/>
        <Button x:Name="BtnInputMode_M" Visibility="Collapsed"/>
        <Button x:Name="BtnAutoTidy" Visibility="Collapsed"/>
        <Button x:Name="BtnClear" Visibility="Collapsed"/>
        <Button x:Name="BtnRecognize" Visibility="Collapsed"/>
        <Button x:Name="BtnCalc" Visibility="Collapsed"/>
        <Button x:Name="BtnAutoTidyBtn" Visibility="Collapsed"/>
        <Button x:Name="BtnLayout" Visibility="Collapsed"/>
        <Border x:Name="ModernToolbar" Visibility="Collapsed"/>
        <Border x:Name="LeftToolbar" Visibility="Collapsed"/>
        <StackPanel x:Name="ClassicTemplatePanel" Visibility="Collapsed"/>
        <Button x:Name="BtnInputMode" Visibility="Collapsed"/>
    </Grid>
</Window>