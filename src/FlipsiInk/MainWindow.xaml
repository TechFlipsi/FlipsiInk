<Window x:Class="FlipsiInk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlipsiInk"
        Title="FlipsiInk"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <DockPanel>
        <!-- Tab Bar (Issue #21) -->
        <local:TabBarControl DockPanel.Dock="Top" x:Name="TabBar" Height="32"/>

        <!-- Top Bar -->
        <DockPanel DockPanel.Dock="Top" Background="#2D2D2D" Height="48" x:Name="TopBar">
            <StackPanel Orientation="Horizontal" Margin="8,0">
                <TextBlock Text="🖊️ FlipsiInk" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="8,0,16,0" x:Name="AppTitle"/>
                <TextBlock x:Name="VersionLabel" Text="v0.1.0" FontSize="11" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,16,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0">
                <!-- Zoom Controls -->
                <Button x:Name="BtnZoomOut" Content="🔍−" Style="{StaticResource ToolButton}" ToolTip="Verkleinern"/>
                <TextBlock x:Name="ZoomLabel" Text="100%" Foreground="White" VerticalAlignment="Center" FontSize="12" Margin="4,0" Width="45" TextAlignment="Center"/>
                <Button x:Name="BtnZoomIn" Content="🔍+" Style="{StaticResource ToolButton}" ToolTip="Vergrößern"/>
                <Button x:Name="BtnZoomReset" Content="📐" Style="{StaticResource ToolButton}" ToolTip="Seitengröße"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnUndo" Content="↩️" Style="{StaticResource ToolButton}" ToolTip="Rückgängig (Ctrl+Z)"/>
                <Button x:Name="BtnRedo" Content="↪️" Style="{StaticResource ToolButton}" ToolTip="Wiederholen (Ctrl+Y)"/>
                <Button x:Name="BtnClear" Content="🗑️" Style="{StaticResource ToolButton}" ToolTip="Alles löschen"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnRecognize" Content="🔤" Style="{StaticResource ToolButton}" ToolTip="Text erkennen (Ctrl+Shift+R)" Background="#0078D7"/>
                <Button x:Name="BtnCalc" Content="🧮" Style="{StaticResource ToolButton}" ToolTip="Mathe berechnen (Ctrl+Shift+M)" Background="#0078D7"/>
                <Button x:Name="BtnAutoTidy" Content="✨" Style="{StaticResource ToolButton}" ToolTip="Auto-Tidy: Layout aufräumen" Background="#0078D7"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnNotebooks" Content="📓" Style="{StaticResource ToolButton}" ToolTip="Notizbücher"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnSave" Content="💾" Style="{StaticResource ToolButton}" ToolTip="Speichern"/>
                <Button x:Name="BtnExport" Content="📤" Style="{StaticResource ToolButton}" ToolTip="Export &amp; Teilen (Ctrl+E)"/>
                <Button x:Name="BtnTheme" Content="🌓" Style="{StaticResource ToolButton}" ToolTip="Theme wechseln"/>
                <Button x:Name="BtnLayout" Content="📐" Style="{StaticResource ToolButton}" ToolTip="Layout wechseln (Klassisch/Modern)"/>
                <Button x:Name="BtnModelManager" Content="📦" Style="{StaticResource ToolButton}" ToolTip="KI-Modelle verwalten"/>
                <Button x:Name="BtnSettings" Content="⚙️" Style="{StaticResource ToolButton}" ToolTip="Einstellungen"/>
                <Button x:Name="BtnCheckUpdate" Content="🔄" Style="{StaticResource ToolButton}" ToolTip="Nach Update suchen"/>
                <Separator Margin="4,8"/>
                <ToggleButton x:Name="BtnBookmarks" Content="🔖" Style="{StaticResource ToolButton}" ToolTip="Lesezeichen"/>
                <ToggleButton x:Name="BtnBacklinks" Content="🔗" Style="{StaticResource ToolButton}" ToolTip="Rückverweise"/>
                <Button x:Name="BtnRecentFiles" Content="📁" Style="{StaticResource ToolButton}" ToolTip="Zuletzt geöffnet"/>
            </StackPanel>
        </DockPanel>

        <!-- ========== MODERN LAYOUT: Horizontal Toolbar ========== -->
        <Border DockPanel.Dock="Top" Background="#252525" Padding="8,4" x:Name="ModernToolbar" Visibility="Visible">
            <StackPanel Orientation="Horizontal">
                <!-- Drawing Tools -->
                <Button x:Name="BtnPen_M" Content="✏️" Style="{StaticResource ToolButton}" ToolTip="Stift" Background="#0078D7"/>
                <Button x:Name="BtnHighlighter_M" Content="🖍️" Style="{StaticResource ToolButton}" ToolTip="Textmarker"/>
                <Button x:Name="BtnEraser_M" Content="🧹" Style="{StaticResource ToolButton}" ToolTip="Radierer"/>
                <Button x:Name="BtnSelect_M" Content="👆" Style="{StaticResource ToolButton}" ToolTip="Auswählen"/>
                <Separator Margin="4,4"/>
                <!-- Shapes -->
                <Button x:Name="BtnLine_M" Content="📏" Style="{StaticResource ToolButton}" ToolTip="Linie"/>
                <Button x:Name="BtnRect_M" Content="⬜" Style="{StaticResource ToolButton}" ToolTip="Rechteck"/>
                <Button x:Name="BtnCircle_M" Content="⭕" Style="{StaticResource ToolButton}" ToolTip="Kreis"/>
                <Separator Margin="4,4"/>
                <!-- Colors -->
                <Button x:Name="BtnBlack_M" Content="⚫" Style="{StaticResource ToolButton}" ToolTip="Schwarz"/>
                <Button x:Name="BtnBlue_M" Content="🔵" Style="{StaticResource ToolButton}" ToolTip="Blau"/>
                <Button x:Name="BtnRed_M" Content="🔴" Style="{StaticResource ToolButton}" ToolTip="Rot"/>
                <Button x:Name="BtnGreen_M" Content="🟢" Style="{StaticResource ToolButton}" ToolTip="Grün"/>
                <Separator Margin="4,4"/>
                <!-- Sizes -->
                <Button x:Name="BtnThin_M" Content="▪️" Style="{StaticResource ToolButton}" ToolTip="Dünn" FontSize="10"/>
                <Button x:Name="BtnMedium_M" Content="◼️" Style="{StaticResource ToolButton}" ToolTip="Mittel"/>
                <Button x:Name="BtnThick_M" Content="⬛" Style="{StaticResource ToolButton}" ToolTip="Dick"/>
                <Separator Margin="4,4"/>
                <!-- Template & Input Mode -->
                <ComboBox x:Name="TemplateCombo_M" Width="140" Margin="4,0" ToolTip="Seitenvorlage">
                    <ComboBoxItem Content="Blanko" IsSelected="True"/>
                    <ComboBoxItem Content="Liniert (breit)"/>
                    <ComboBoxItem Content="Liniert (schmal)"/>
                    <ComboBoxItem Content="Kariert (klein)"/>
                    <ComboBoxItem Content="Kariert (mittel)"/>
                    <ComboBoxItem Content="Kariert (groß)"/>
                    <ComboBoxItem Content="Punktiert (klein)"/>
                    <ComboBoxItem Content="Punktiert (mittel)"/>
                    <ComboBoxItem Content="Punktiert (groß)"/>
                    <ComboBoxItem Content="Cornell Notes"/>
                    <ComboBoxItem Content="Isometrisch"/>
                </ComboBox>
                <Button x:Name="BtnAutoTidy_M" Content="✨" Style="{StaticResource ToolButton}" ToolTip="Auto-Tidy: Layout aufräumen" Background="#0078D7"/>
                <Separator Margin="4,4"/>
                <Button x:Name="BtnInputMode_M" Content="🖊️" Style="{StaticResource ToolButton}" ToolTip="Eingabe-Modus: Stift/Touch/Beide"/>
                <Separator Margin="4,4"/>
                <ToggleButton x:Name="BtnStickyNote_M" Content="📝" Style="{StaticResource ToolButton}" ToolTip="Klebezettel-Modus"/>
            </StackPanel>
        </Border>

        <!-- ========== CLASSIC LAYOUT: Left Toolbar ========== -->
        <Border DockPanel.Dock="Left" Background="#252525" Width="56" Padding="4" x:Name="LeftToolbar" Visibility="Collapsed">
            <StackPanel>
                <Button x:Name="BtnPen" Content="✏️" Style="{StaticResource ToolButton}" ToolTip="Stift" Background="#0078D7"/>
                <Button x:Name="BtnHighlighter" Content="🖍️" Style="{StaticResource ToolButton}" ToolTip="Textmarker"/>
                <Button x:Name="BtnEraser" Content="🧹" Style="{StaticResource ToolButton}" ToolTip="Radierer"/>
                <Button x:Name="BtnSelect" Content="👆" Style="{StaticResource ToolButton}" ToolTip="Auswählen"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnLine" Content="📏" Style="{StaticResource ToolButton}" ToolTip="Linie"/>
                <Button x:Name="BtnRect" Content="⬜" Style="{StaticResource ToolButton}" ToolTip="Rechteck"/>
                <Button x:Name="BtnCircle" Content="⭕" Style="{StaticResource ToolButton}" ToolTip="Kreis"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnBlack" Content="⚫" Style="{StaticResource ToolButton}" ToolTip="Schwarz"/>
                <Button x:Name="BtnBlue" Content="🔵" Style="{StaticResource ToolButton}" ToolTip="Blau"/>
                <Button x:Name="BtnRed" Content="🔴" Style="{StaticResource ToolButton}" ToolTip="Rot"/>
                <Button x:Name="BtnGreen" Content="🟢" Style="{StaticResource ToolButton}" ToolTip="Grün"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnThin" Content="▪️" Style="{StaticResource ToolButton}" ToolTip="Dünn" FontSize="10"/>
                <Button x:Name="BtnMedium" Content="◼️" Style="{StaticResource ToolButton}" ToolTip="Mittel"/>
                <Button x:Name="BtnThick" Content="⬛" Style="{StaticResource ToolButton}" ToolTip="Dick"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnTemplate" Content="📄" Style="{StaticResource ToolButton}" ToolTip="Seitenvorlage"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnAutoTidy_C" Content="✨" Style="{StaticResource ToolButton}" ToolTip="Auto-Tidy: Layout aufräumen"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnInputMode" Content="🖊️" Style="{StaticResource ToolButton}" ToolTip="Eingabe-Modus: Stift/Touch/Beide"/>
                <Separator Margin="4,8"/>
                <ToggleButton x:Name="BtnStickyNote" Content="📝" Style="{StaticResource ToolButton}" ToolTip="Klebezettel-Modus"/>
            </StackPanel>
        </Border>

        <!-- Left: Page Thumbnail Strip (Issue #15) -->
        <local:PageThumbnailControl x:Name="PageThumbnails" DockPanel.Dock="Left" Width="100"/>

        <!-- Left: Bookmark Panel (Issue #21) -->
        <local:BookmarkPanel x:Name="BookmarkSidebar" DockPanel.Dock="Left" Visibility="Collapsed"/>

        <!-- Left: Backlinks Panel (Issue #33) -->
        <local:BacklinksPanel x:Name="BacklinksSidebar" DockPanel.Dock="Left" Visibility="Collapsed"/>

        <!-- Recent Files Popup (Issue #21) -->
        <Popup x:Name="RecentFilesPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnRecentFiles}" StaysOpen="False" AllowsTransparency="True">
            <Border Background="#2D2D2D" CornerRadius="4" Padding="8" MinWidth="200" MaxHeight="300">
                <StackPanel>
                    <TextBlock Text="Zuletzt geöffnet" FontWeight="Bold" Foreground="White" FontSize="13" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="RecentFilesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Background="Transparent" Foreground="White" BorderThickness="0" Padding="4,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Cursor="Hand" Click="RecentFile_Click" FontSize="12" Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Right Panel: Recognition Results -->
        <Border DockPanel.Dock="Right" Background="#252525" Width="280" Padding="12" x:Name="RightPanel">
            <StackPanel>
                <TextBlock Text="🔤 Erkannter Text" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                <TextBox x:Name="RecognizedText" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="150" VerticalScrollBarVisibility="Auto"
                         Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#444"
                         FontSize="14" IsReadOnly="True"/>

                <TextBlock Text="🧮 Mathe-Ergebnis" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,16,0,8"/>
                <TextBox x:Name="MathResult" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="100" VerticalScrollBarVisibility="Auto"
                         Background="#1E1E1E" Foreground="#4CAF50" BorderThickness="1" BorderBrush="#444"
                         FontSize="16" FontWeight="Bold" IsReadOnly="True"/>

                <TextBlock Text="📊 Status" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,16,0,8"/>
                <TextBlock x:Name="StatusText" Text="Bereit" Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
                <TextBlock x:Name="PageIndicator" Text="Seite 1/1" Foreground="#0078D7" FontWeight="Bold" FontSize="12" Margin="0,8,0,0"/>

                <TextBlock x:Name="ModelStatus" Text="Modell: nicht geladen" Foreground="#FF6600" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>

                <!-- Smart-Detection Links (Issue #30) -->
                <StackPanel x:Name="SmartLinksPanel" Visibility="Collapsed" Margin="0,12,0,0">
                    <TextBlock Text="🔗 Erkannte Links" FontWeight="Bold" Foreground="White" FontSize="13" Margin="0,0,0,4"/>
                    <ItemsControl x:Name="SmartLinksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,2">
                                    <Hyperlink NavigateUri="{Binding Uri}" RequestNavigate="SmartLink_Navigate" Foreground="#4CAF50">
                                        <Run Text="{Binding Label}"/>
                                    </Hyperlink>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Suche-Button (Issue #30) -->
                <Button x:Name="BtnSearch" Content="🔍 Notizen durchsuchen" Style="{StaticResource ToolButton}" ToolTip="Volltextsuche in gespeicherten Notizen" Margin="0,12,0,0" HorizontalAlignment="Stretch"/>

                <!-- Template Preview (Classic only – Modern has it in toolbar) -->
                <StackPanel x:Name="ClassicTemplatePanel" Visibility="Collapsed">
                    <TextBlock Text="📄 Vorlage" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,16,0,8"/>
                    <ComboBox x:Name="TemplateCombo" Margin="0,0,0,4">
                        <ComboBoxItem Content="Blanko" IsSelected="True"/>
                        <ComboBoxItem Content="Liniert (breit)"/>
                        <ComboBoxItem Content="Liniert (schmal)"/>
                        <ComboBoxItem Content="Kariert (klein)"/>
                        <ComboBoxItem Content="Kariert (mittel)"/>
                        <ComboBoxItem Content="Kariert (groß)"/>
                        <ComboBoxItem Content="Punktiert (klein)"/>
                        <ComboBoxItem Content="Punktiert (mittel)"/>
                        <ComboBoxItem Content="Punktiert (groß)"/>
                        <ComboBoxItem Content="Cornell Notes"/>
                        <ComboBoxItem Content="Isometrisch"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Canvas Area with Zoom -->
        <ScrollViewer x:Name="CanvasScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="CanvasGrid">
                <InkCanvas x:Name="MainCanvas" Background="White" Width="1200" Height="1600"/>
                <!-- Sticky Note overlay (floats above ink strokes) -->
                <!-- Sticky Note overlay (floats above ink strokes) -->
                <Canvas x:Name="StickyNoteOverlay" Width="1200" Height="1600" Background="{x:Null}" ClipToBounds="True"/>
                <!-- Kontext-sensitive Aktionsleiste (Issue #35) -->
                <Popup x:Name="ContextActionPopup" Placement="Relative" PlacementTarget="{Binding ElementName=CanvasGrid}" AllowsTransparency="True" StaysOpen="False">
                    <Border Background="#2D2D2D" CornerRadius="6" Padding="4,2" BorderBrush="#0078D7" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" x:Name="ContextActionPanel"/>
                    </Border>
                </Popup>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>