<Border x:Class="FlipsiInk.BacklinksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#252525" Width="240" Padding="12">
    <StackPanel>
        <!-- Backlinks section -->
        <TextBlock Text="Rückverweise" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
        <ItemsControl x:Name="BacklinksList" MaxHeight="200">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding DisplayName}" Background="Transparent" Foreground="#4FC3F7"
                            BorderThickness="0" Padding="4,2" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Cursor="Hand" FontSize="12" Margin="0,1"
                            Click="Backlink_Click" Tag="{Binding TargetNotebookName}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock x:Name="NoBacklinksText" Text="Keine Rückverweise" Foreground="Gray" FontSize="11" Margin="0,2" Visibility="Visible"/>

        <Separator Margin="0,12" Background="#444"/>

        <!-- Outgoing links section -->
        <TextBlock Text="Ausgehende Verknüpfungen" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
        <ItemsControl x:Name="OutgoingLinksList" MaxHeight="200">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Margin="0,2" Foreground="#4FC3F7" TextDecorations="Underline"
                               FontSize="12" Cursor="Hand" Tag="{Binding TargetNotebookName}">
                        <Hyperlink Click="OutgoingLink_Click" Foreground="#4FC3F7" Tag="{Binding TargetNotebookName}">
                            <Run Text="{Binding TargetNotebookName}"/>
                        </Hyperlink>
                    </TextBlock>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock x:Name="NoOutgoingText" Text="Keine ausgehenden Verknüpfungen" Foreground="Gray" FontSize="11" Margin="0,2" Visibility="Visible"/>

        <Separator Margin="0,12" Background="#444"/>

        <!-- Unlinked mentions section -->
        <TextBlock Text="💭 Erwähnungen ohne Verknüpfung" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
        <ItemsControl x:Name="UnlinkedMentionsList" MaxHeight="150">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Margin="0,2" Foreground="#FFA726" FontSize="12" TextWrapping="Wrap">
                        <Run Text="{Binding}"/>
                    </TextBlock>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock x:Name="NoUnlinkedText" Text="Keine unverknüpften Erwähnungen" Foreground="Gray" FontSize="11" Margin="0,2" Visibility="Visible"/>
    </StackPanel>
</Border>