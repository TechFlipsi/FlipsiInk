<Window x:Class="FlipsiInk.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen" Width="480" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E1E"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SettingsHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style x:Key="SettingsCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A8FEF" TargetName="bg"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="#444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#555" TargetName="bg"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="Einstellungen" Style="{StaticResource SettingsHeader}" FontSize="20"/>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Style="{StaticResource CancelButton}" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Speichern" Style="{StaticResource ActionButton}" Click="Save_Click"/>
        </StackPanel>

        <!-- Settings Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Theme -->
                <TextBlock Text="Theme" Style="{StaticResource SettingsLabel}"/>
                <ComboBox x:Name="ThemeCombo" Style="{StaticResource SettingsCombo}" SelectedIndex="0">
                    <ComboBoxItem Content="System"/>
                    <ComboBoxItem Content="Hell"/>
                    <ComboBoxItem Content="Dunkel"/>
                </ComboBox>

                <!-- Default Template -->
                <TextBlock Text="Standard-Seitenvorlage" Style="{StaticResource SettingsLabel}"/>
                <ComboBox x:Name="TemplateCombo" Style="{StaticResource SettingsCombo}" SelectedIndex="1">
                    <ComboBoxItem Content="Blanko"/>
                    <ComboBoxItem Content="Liniert (breit)"/>
                    <ComboBoxItem Content="Liniert (schmal)"/>
                    <ComboBoxItem Content="Kariert (klein)"/>
                    <ComboBoxItem Content="Kariert (mittel)"/>
                    <ComboBoxItem Content="Kariert (groß)"/>
                    <ComboBoxItem Content="Punktiert (klein)"/>
                    <ComboBoxItem Content="Punktiert (mittel)"/>
                    <ComboBoxItem Content="Punktiert (groß)"/>
                    <ComboBoxItem Content="Cornell Notes"/>
                    <ComboBoxItem Content="Isometrisch"/>
                </ComboBox>

                <!-- Default Pen Color -->
                <TextBlock Text="Standard-Stiftfarbe" Style="{StaticResource SettingsLabel}"/>
                <ComboBox x:Name="PenColorCombo" Style="{StaticResource SettingsCombo}" SelectedIndex="0">
                    <ComboBoxItem Content="Schwarz"/>
                    <ComboBoxItem Content="Dunkelblau"/>
                    <ComboBoxItem Content="Blau"/>
                    <ComboBoxItem Content="Rot"/>
                    <ComboBoxItem Content="Grün"/>
                    <ComboBoxItem Content="Orange"/>
                    <ComboBoxItem Content="Lila"/>
                    <ComboBoxItem Content="Braun"/>
                    <ComboBoxItem Content="Grau"/>
                    <ComboBoxItem Content="Türkis"/>
                </ComboBox>

                <!-- Default Pen Thickness -->
                <TextBlock Text="Standard-Stiftdicke" Style="{StaticResource SettingsLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton x:Name="PenThin" Content="Dünn (1px)" Foreground="#CCC" FontSize="13" Margin="0,0,16,0" GroupName="PenSize"/>
                    <RadioButton x:Name="PenMedium" Content="Mittel (2.5px)" Foreground="#CCC" FontSize="13" Margin="0,0,16,0" GroupName="PenSize" IsChecked="True"/>
                    <RadioButton x:Name="PenThick" Content="Dick (5px)" Foreground="#CCC" FontSize="13" GroupName="PenSize"/>
                </StackPanel>

                <!-- Language -->
                <TextBlock Text="Sprache" Style="{StaticResource SettingsLabel}"/>
                <ComboBox x:Name="LanguageCombo" Style="{StaticResource SettingsCombo}" SelectedIndex="0">
                    <ComboBoxItem Content="Deutsch"/>
                    <ComboBoxItem Content="English"/>
                </ComboBox>

                <!-- Auto-save -->
                <TextBlock Text="Auto-Speichern Intervall (Minuten, 0 = deaktiviert)" Style="{StaticResource SettingsLabel}"/>
                <TextBox x:Name="AutoSaveInterval" Style="{StaticResource SettingsTextBox}" Text="0"/>

                <!-- Canvas opacity -->
                <TextBlock Text="Vorlagen-Deckkraft (0.0 - 1.0)" Style="{StaticResource SettingsLabel}"/>
                <TextBox x:Name="CanvasOpacity" Style="{StaticResource SettingsTextBox}" Text="1.0"/>

                <!-- Startup behavior -->
                <TextBlock Text="Startverhalten" Style="{StaticResource SettingsLabel}"/>
                <ComboBox x:Name="StartupCombo" Style="{StaticResource SettingsCombo}" SelectedIndex="0">
                    <ComboBoxItem Content="Leeres Notizbuch starten"/>
                    <ComboBoxItem Content="Letztes Notizbuch öffnen"/>
                </ComboBox>

                <!-- Toolbar layout -->
                <TextBlock Text="Toolbar-Layout" Style="{StaticResource SettingsLabel}"/>
                <ComboBox x:Name="ToolbarLayoutCombo" Style="{StaticResource SettingsCombo}" SelectedIndex="0">
                    <ComboBoxItem Content="Modern (horizontal)"/>
                    <ComboBoxItem Content="Klassisch (vertikal)"/>
                </ComboBox>

                <!-- Auto-update -->
                <CheckBox x:Name="AutoUpdateCheck" Content="Automatisch nach Updates suchen" Style="{StaticResource SettingsCheckBox}" IsChecked="True"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>