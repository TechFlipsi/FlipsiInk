<Window x:Class="FlipsiInk.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notizen durchsuchen"
        Width="600" Height="450"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sucheingabe -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     FontSize="16"
                     Padding="8,6"
                     Background="#2D2D2D" Foreground="White"
                     BorderBrush="#0078D7" BorderThickness="1"
                     KeyDown="SearchBox_KeyDown"/>
            <Button x:Name="BtnSearch"
                    Grid.Column="1"
                    Content="Suchen"
                    Margin="8,0,0,0"
                    Padding="16,6"
                    Background="#0078D7" Foreground="White"
                    FontWeight="Bold"
                    Click="BtnSearch_Click"/>
        </Grid>

        <!-- Ergebnisse -->
        <ListView x:Name="ResultsList"
                  Grid.Row="1"
                  Background="#252525" Foreground="White"
                  BorderThickness="1" BorderBrush="#444"
                  SelectionMode="Single"
                  MouseDoubleClick="ResultsList_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Datei" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Filename}" Foreground="White" FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Ausschnitt" Width="300">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Snippet}" Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="🕐 Datum" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayDate}" Foreground="#888888" FontSize="11"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Statusleiste -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock x:Name="StatusLabel" Text="Geben Sie einen Suchbegriff ein" Foreground="Gray" FontSize="12"/>
            <TextBlock x:Name="ResultCount" Text="" Foreground="#0078D7" FontSize="12" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>