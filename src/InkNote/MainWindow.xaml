<Window x:Class="InkNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InkNote"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <DockPanel>
        <!-- Top Bar -->
        <DockPanel DockPanel.Dock="Top" Background="#2D2D2D" Height="48">
            <StackPanel Orientation="Horizontal" Margin="8,0">
                <TextBlock Text="📝 InkNote" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="8,0,16,0"/>
                <TextBlock x:Name="VersionLabel" Text="v0.1.0" FontSize="11" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,16,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0">
                <Button x:Name="BtnUndo" Content="↩️" Style="{StaticResource ToolButton}" ToolTip="Rückgängig"/>
                <Button x:Name="BtnRedo" Content="↪️" Style="{StaticResource ToolButton}" ToolTip="Wiederholen"/>
                <Button x:Name="BtnClear" Content="🗑️" Style="{StaticResource ToolButton}" ToolTip="Alles löschen"/>
                <Button x:Name="BtnRecognize" Content="🔤" Style="{StaticResource ToolButton}" ToolTip="Text erkennen" Background="#0078D7"/>
                <Button x:Name="BtnCalc" Content="🧮" Style="{StaticResource ToolButton}" ToolTip="Mathe berechnen" Background="#0078D7"/>
                <Button x:Name="BtnSave" Content="💾" Style="{StaticResource ToolButton}" ToolTip="Speichern"/>
                <Button x:Name="BtnSettings" Content="⚙️" Style="{StaticResource ToolButton}" ToolTip="Einstellungen"/>
            </StackPanel>
        </DockPanel>

        <!-- Left Toolbar -->
        <Border DockPanel.Dock="Left" Background="#252525" Width="56" Padding="4">
            <StackPanel>
                <Button x:Name="BtnPen" Content="✏️" Style="{StaticResource ToolButton}" ToolTip="Stift" Background="#0078D7"/>
                <Button x:Name="BtnHighlighter" Content="🖍️" Style="{StaticResource ToolButton}" ToolTip="Textmarker"/>
                <Button x:Name="BtnEraser" Content="🧹" Style="{StaticResource ToolButton}" ToolTip="Radierer"/>
                <Button x:Name="BtnSelect" Content="👆" Style="{StaticResource ToolButton}" ToolTip="Auswählen"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnLine" Content="📏" Style="{StaticResource ToolButton}" ToolTip="Linie"/>
                <Button x:Name="BtnRect" Content="⬜" Style="{StaticResource ToolButton}" ToolTip="Rechteck"/>
                <Button x:Name="BtnCircle" Content="⭕" Style="{StaticResource ToolButton}" ToolTip="Kreis"/>
                <Separator Margin="4,8"/>
                <!-- Color buttons -->
                <Button x:Name="BtnBlack" Content="⚫" Style="{StaticResource ToolButton}" ToolTip="Schwarz"/>
                <Button x:Name="BtnBlue" Content="🔵" Style="{StaticResource ToolButton}" ToolTip="Blau"/>
                <Button x:Name="BtnRed" Content="🔴" Style="{StaticResource ToolButton}" ToolTip="Rot"/>
                <Button x:Name="BtnGreen" Content="🟢" Style="{StaticResource ToolButton}" ToolTip="Grün"/>
                <Separator Margin="4,8"/>
                <Button x:Name="BtnThin" Content="▪️" Style="{StaticResource ToolButton}" ToolTip="Dünn" FontSize="10"/>
                <Button x:Name="BtnMedium" Content="◼️" Style="{StaticResource ToolButton}" ToolTip="Mittel"/>
                <Button x:Name="BtnThick" Content="⬛" Style="{StaticResource ToolButton}" ToolTip="Dick"/>
            </StackPanel>
        </Border>

        <!-- Right Panel: Recognition Results -->
        <Border DockPanel.Dock="Right" Background="#252525" Width="280" Padding="12" x:Name="RightPanel">
            <StackPanel>
                <TextBlock Text="🔤 Erkannter Text" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                <TextBox x:Name="RecognizedText" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="150" VerticalScrollBarVisibility="Auto"
                         Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#444"
                         FontSize="14" IsReadOnly="True"/>
                
                <TextBlock Text="🧮 Mathe-Ergebnis" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,16,0,8"/>
                <TextBox x:Name="MathResult" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="100" VerticalScrollBarVisibility="Auto"
                         Background="#1E1E1E" Foreground="#4CAF50" BorderThickness="1" BorderBrush="#444"
                         FontSize="16" FontWeight="Bold" IsReadOnly="True"/>

                <TextBlock Text="📊 Status" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,16,0,8"/>
                <TextBlock x:Name="StatusText" Text="Bereit" Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
                
                <TextBlock x:Name="ModelStatus" Text="Modell: nicht geladen" Foreground="#FF6600" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Canvas -->
        <InkCanvas x:Name="MainCanvas" Background="#FAFAFA"/>
    </DockPanel>
</Window>